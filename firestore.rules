rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isStaff() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }
    
    match /inventory/{document} {
      allow read: if isAdmin() || isStaff();
      allow delete, create: if isAdmin();
      allow update: if isAdmin() || (isStaff() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['price', 'cost']));
    }
    
    match /recipes/{document} {
      allow read: if isAdmin() || isStaff();
      allow write: if isAdmin();
    }
    
    match /waste_log/{document} {
      allow update, delete: if isAdmin();
      allow create: if isStaff() || isAdmin();
      allow read: if isAdmin() || isStaff();
    }
    
    match /orders/{document} {
      allow update, delete: if isAdmin();
      allow create: if isStaff() || isAdmin();
      allow read: if isAdmin() || isStaff();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId || isAdmin();
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
